<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FF Diamond Top-Up (Prank)</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0f0f0f;
      color: #fff;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }
    .box {
      background: #1c1c1c;
      padding: 25px;
      border-radius: 15px;
      width: 320px;
      text-align: center;
      box-shadow: 0 0 20px rgba(255, 165, 0, 0.4);
    }
    input, select, button {
      width: 100%;
      padding: 10px;
      margin-top: 10px;
      border-radius: 8px;
      border: none;
    }
    button {
      background: orange;
      color: black;
      font-weight: bold;
      cursor: pointer;
    }
    .hidden { display: none; }
    .loader {
      margin-top: 10px;
      font-size: 14px;
      color: orange;
    }
    .success {
      margin-top: 15px;
      color: lightgreen;
    }
  </style>
</head>
<body>
  <div class="box">
    <h2>FF Diamond Top-Up</h2>
    <input type="text" id="uid" placeholder="Enter UID" />
    <button onclick="checkUID()">Check Player</button>

    <div id="loader" class="loader hidden">Checking UID...</div>

    <div id="player" class="hidden">
      <p id="name"></p>
      <select id="diamonds">
        <option>100 Diamonds</option>
        <option>310 Diamonds</option>
        <option>520 Diamonds</option>
        <option>1060 Diamonds</option>
        <option>2180 Diamonds</option>
      </select>
      <button onclick="topup()">Top-Up Now</button>
    </div>

    <div id="result" class="success hidden">
      ✅ Diamonds Successfully Added!
      <p style="font-size:10px; color:gray;">(This is a prank/demo site)</p>
    </div>
  </div>

  <script>
    function randomName() {
      const names = ["DARK•DEVIL", "KING_OP", "PRO_GAMER", "SHADOW_X", "SNIPER_BOY"];
      return names[Math.floor(Math.random() * names.length)];
    }

    function checkUID() {
      const uid = document.getElementById("uid").value;
      if (uid === "") {
        alert("Enter UID first!");
        return;
      }

      document.getElementById("loader").classList.remove("hidden");

      setTimeout(() => {
        document.getElementById("loader").classList.add("hidden");
        document.getElementById("player").classList.remove("hidden");
        document.getElementById("name").innerText = "Player: " + randomName();
      }, 2000);
    }

    function topup() {
      document.getElementById("loader").innerText = "Processing Top-Up...";
      document.getElementById("loader").classList.remove("hidden");

      setTimeout(() => {
        document.getElementById("loader").classList.add("hidden");
        document.getElementById("result").classList.remove("hidden");
      }, 2500);
    }
  </script>
</body>
</html>
